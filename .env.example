# =============================================================================
# RootPilot AI Platform — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values. All variables are optional
# unless marked REQUIRED. Uncommented lines show the default value.
# =============================================================================

# ── Shared (all BaseAppSettings services) ──────────────────────────────────

SERVICE_NAME=rootpilot-service
# ENVIRONMENT=local          # local, development, staging, production, test
# DEBUG=false
# LOG_LEVEL=INFO             # DEBUG, INFO, WARNING, ERROR, CRITICAL
# OTEL_SERVICE_NAME=         # falls back to SERVICE_NAME if empty
# OTEL_EXPORTER_OTLP_ENDPOINT=  # e.g. http://otel-collector:4318


# ── Ingestion Service ──────────────────────────────────────────────────────

# HOST=0.0.0.0
# PORT=8000
# EVENT_BUS_URL=amqp://rootpilot:rootpilot@localhost:5672/
# MAX_PAYLOAD_SIZE=1048576  # bytes (1–10_485_760)


# ── Correlation Service ────────────────────────────────────────────────────

# HOST=0.0.0.0
# PORT=8001
# EVENT_BUS_URL=amqp://rootpilot:rootpilot@localhost:5672/
# TIMELINE_WINDOW_DURATION=300  # seconds


# ── AI Investigation Service (prefix INVESTIGATION_) ───────────────────────

# INVESTIGATION_SERVICE_NAME=ai-investigation-service
# INVESTIGATION_ENVIRONMENT=development
# INVESTIGATION_DEBUG=false
# INVESTIGATION_LOG_LEVEL=INFO
# INVESTIGATION_LLM_PROVIDER=openai
# INVESTIGATION_LLM_MODEL=gpt-4o
# INVESTIGATION_LLM_TEMPERATURE=0.1
# INVESTIGATION_LLM_MAX_TOKENS=4096


# ── OpenAI LLM Provider (prefix OPENAI_) ───────────────────────────────────

OPENAI_API_KEY=                # REQUIRED for AI investigation
# OPENAI_DEFAULT_MODEL=gpt-4o
# OPENAI_DEFAULT_TEMPERATURE=0.1
# OPENAI_DEFAULT_MAX_TOKENS=4096
# OPENAI_TIMEOUT_SECONDS=60


# ── Docker Compose Infrastructure ──────────────────────────────────────────
# These are set in docker-compose.yml but can be overridden via .env.

# RABBITMQ_DEFAULT_USER=rootpilot
# RABBITMQ_DEFAULT_PASS=rootpilot
# POSTGRES_USER=rootpilot
# POSTGRES_PASSWORD=rootpilot
# POSTGRES_DB=rootpilot
# ES_JAVA_OPTS=-Xms512m -Xmx512m
