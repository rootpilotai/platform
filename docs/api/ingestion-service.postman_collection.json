{
  "info": {
    "name": "RootPilot - ingestion-service",
    "description": "Telemetry ingestion and normalization API.\n\nBase URL: {{base_url}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "rootpilot"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "event_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Body has required fields\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.all.keys(\"status\", \"service\", \"environment\", \"event_bus_connected\");",
                  "    pm.expect(json.service).to.eql(\"ingestion-service\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Ingestion",
      "item": [
        {
          "name": "Ingest CPU metric",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 202\", () => pm.response.to.have.status(202));",
                  "pm.test(\"Body has accepted=true and event_id\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.accepted).to.be.true;",
                  "    pm.expect(json.event_id).to.match(/^[a-f0-9]{32}$/);",
                  "    pm.collectionVariables.set(\"event_id\", json.event_id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metric\": \"cpu.usage\",\n  \"value\": 75.5,\n  \"unit\": \"%\",\n  \"tags\": {\n    \"host\": \"web-01\",\n    \"region\": \"us-east-1\"\n  },\n  \"source\": \"web-service\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/ingest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ingest"]
            }
          }
        },
        {
          "name": "Ingest memory metric",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 202\", () => pm.response.to.have.status(202));",
                  "pm.test(\"accepted is true\", () => pm.expect(pm.response.json().accepted).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metric\": \"mem.usage\",\n  \"value\": 4096,\n  \"unit\": \"MB\",\n  \"tags\": {\n    \"host\": \"db-01\"\n  },\n  \"source\": \"db-service\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/ingest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ingest"]
            }
          }
        },
        {
          "name": "Ingest minimal (no unit/tags)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 202\", () => pm.response.to.have.status(202));",
                  "pm.test(\"accepted is true\", () => pm.expect(pm.response.json().accepted).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metric\": \"requests.count\",\n  \"value\": 100,\n  \"source\": \"api-gateway\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/ingest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ingest"]
            }
          }
        },
        {
          "name": "Ingest with timestamp",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 202\", () => pm.response.to.have.status(202));",
                  "pm.test(\"accepted is true\", () => pm.expect(pm.response.json().accepted).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metric\": \"latency\",\n  \"value\": 150.0,\n  \"unit\": \"ms\",\n  \"source\": \"api-gateway\",\n  \"timestamp\": \"2026-06-12T10:00:00+00:00\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/ingest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ingest"]
            }
          }
        }
      ]
    },
    {
      "name": "Error cases",
      "item": [
        {
          "name": "Missing required fields (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 422\", () => pm.response.to.have.status(422));",
                  "pm.test(\"Body has detail array\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"detail\");",
                  "    pm.expect(json.detail.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metric\": \"cpu\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/ingest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ingest"]
            }
          }
        },
        {
          "name": "Empty body (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 422\", () => pm.response.to.have.status(422));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/ingest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ingest"]
            }
          }
        },
        {
          "name": "Non-numeric value (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 422\", () => pm.response.to.have.status(422));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"metric\": \"cpu\",\n  \"value\": \"high\",\n  \"source\": \"test\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/ingest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "ingest"]
            }
          }
        }
      ]
    }
  ]
}
